{
  "name": "ima2-worldcup",
  "version": "0.1.0",
  "description": "AI style transfer for sports highlights — turn World Cup clips into copyright-safe crayon/watercolor art",
  "type": "module",
  "bin": {
    "ima2w": "bin/ima2w.mjs"
  },
  "files": [
    "bin/",
    ".next/standalone/",
    ".next/static/",
    "public/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:next": "next dev --port 3477",
    "build": "next build",
    "postbuild": "node -e \"const{cpSync,existsSync}=require('fs');const s='.next/standalone';if(existsSync(s)){cpSync('.next/static',s+'/.next/static',{recursive:true});cpSync('public',s+'/public',{recursive:true});console.log('[postbuild] static+public copied')}\"",
    "prepublishOnly": "npm run build",
    "start": "next start",
    "lint": "next lint"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lidge-jun/ima2-worldcup.git"
  },
  "homepage": "https://github.com/lidge-jun/ima2-worldcup",
  "keywords": [
    "ai",
    "style-transfer",
    "ima2",
    "worldcup",
    "sports",
    "copyright",
    "gpt-image",
    "grok"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "pretendard": "^1.3.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
