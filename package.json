{
  "name": "ima2-worldcup",
  "version": "0.1.0",
  "description": "AI style transfer for sports highlights — turn World Cup clips into copyright-safe crayon/watercolor art",
  "type": "module",
  "bin": {
    "ima2w": "bin/ima2w.mjs"
  },
  "files": [
    "bin/",
    "app/",
    "components/",
    "lib/",
    "public/",
    "scripts/",
    "next.config.ts",
    "tsconfig.json",
    "postcss.config.mjs",
    "package.json"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:next": "next dev --port 3477",
    "build": "next build",
    "postbuild": "node -e \"const{cpSync,existsSync,readdirSync}=require('fs');const{execSync}=require('child_process');const s='.next/standalone';if(!existsSync(s))process.exit(0);const found=execSync('find .next/standalone -name server.js -not -path \\\"*/node_modules/*\\\" -type f',{encoding:'utf8'}).trim().split('\\n')[0];if(!found)process.exit(0);const d=require('path').dirname(found);cpSync('.next/static',d+'/.next/static',{recursive:true});cpSync('public',d+'/public',{recursive:true});console.log('[postbuild] copied to '+d)\"",
    "start": "next start",
    "lint": "next lint"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lidge-jun/ima2-worldcup.git"
  },
  "homepage": "https://github.com/lidge-jun/ima2-worldcup",
  "keywords": [
    "ai",
    "style-transfer",
    "ima2",
    "worldcup",
    "sports",
    "copyright",
    "gpt-image",
    "grok"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "pretendard": "^1.3.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
